# Cloud Agent v2 — Environment Variables
# Copy to .env and fill in your values

# === LLM Keys ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default model for the agent (gpt-4o | gpt-4o-mini | claude-sonnet-4-20250514)
DEFAULT_MODEL=gpt-4o

# Fast model for classifiers/routing (cheaper)
FAST_MODEL=gpt-4o-mini

# === AWS Credentials (optional — can also use AWS CLI profiles) ===
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# === Persistence ===
SQLITE_DB_PATH=agent_memory.db
AUDIT_LOG_PATH=audit.jsonl

# === Features ===
PROACTIVE_SCAN_ENABLED=true
PROACTIVE_SCAN_INTERVAL_MINUTES=30
DRY_RUN_DEFAULT=false
