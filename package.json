{
  "name": "cloud-agent-v2",
  "version": "2.0.0",
  "description": "AWS Cloud Agent — multi-agent desktop app",
  "main": "electron/main/index.js",
  "scripts": {
    "dev":         "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer":"vite electron/renderer --config vite.config.js",
    "dev:electron":"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build":       "vite build && electron-builder",
    "lint":        "eslint electron/renderer --ext .jsx,.js"
  },
  "dependencies": {
    "react":              "^18.2.0",
    "react-dom":          "^18.2.0",
    "react-markdown":     "^9.0.1",
    "remark-gfm":         "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer":         "^10.4.19",
    "concurrently":         "^8.2.2",
    "cross-env":            "^7.0.3",
    "electron":             "^30.0.0",
    "electron-builder":     "^24.13.2",
    "postcss":              "^8.4.38",
    "tailwindcss":          "^3.4.4",
    "vite":                 "^5.2.11",
    "wait-on":              "^7.2.0"
  },
  "build": {
    "appId":   "com.cloudagent.v2",
    "productName": "Cloud Agent v2",
    "files":   ["electron/**/*", "dist/**/*", "backend/**/*", "!backend/__pycache__", "!backend/**/*.pyc"],
    "mac": { "category": "public.app-category.developer-tools" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
